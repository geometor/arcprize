          <div class="part-type">executable_code (Language.PYTHON)</div>
          <pre><code>

import numpy as np

def find_blob_center(grid, i, j):
    # Find the center of the blob containing the pixel at (i, j)
    blob_indices = []
    blob_indices.append((i, j))
    visited = set(blob_indices)
    while blob_indices:
        i, j = blob_indices.pop(0)
        for di in range(-1, 2):
            for dj in range(-1, 2):
                new_i, new_j = i + di, j + dj
                if 0 <= new_i < grid.shape[0] and 0 <= new_j < grid.shape[1] and grid[new_i, new_j] == 8 and (new_i, new_j) not in visited:
                    blob_indices.append((new_i, new_j))
                    visited.add((new_i, new_j))
    
    # Calculate the center of the blob
    center_i = sum([i for i, _ in visited]) / len(visited)
    center_j = sum([j for _, j in visited]) / len(visited)
    return center_i, center_j

input_grid = np.array([[0, 0, 0, 0, 0, 8, 8],
                      [8, 8, 0, 0, 0, 0, 8],
                      [8, 0, 0, 0, 0, 0, 0],
                      [0, 0, 0, 8, 0, 0, 0],
                      [0, 0, 0, 8, 8, 0, 0],
                      [0, 8, 0, 0, 0, 0, 0],
                      [8, 8, 0, 0, 0, 0, 0]])

output_grid = np.zeros_like(input_grid)

# Find the bottom-left most pixel for each blob
blob_index = 0
for i in range(input_grid.shape[0]):
    for j in range(input_grid.shape[1]):
        if input_grid[i, j] == 8:
            # Find the bottom-left most Azure pixel in the blob
            center_i, center_j = find_blob_center(input_grid, i, j)
            bottom_left_i, bottom_left_j = i, j
            # Iterate through only the pixels in the same blob
            for k in range(input_grid.shape[0]):
                for l in range(input_grid.shape[1]):
                    if input_grid[k, l] == 8 and abs(k - center_i) + abs(l - center_j) < abs(bottom_left_i - center_i) + abs(bottom_left_j - center_j) and (k > bottom_left_i or (k == bottom_left_i and l < bottom_left_j)):
                        bottom_left_i, bottom_left_j = k, l
            # Replace the bottom-left most Azure pixel with a Blue pixel
            output_grid[bottom_left_i, bottom_left_j] = 1
            blob_index += 1

# Copy the remaining Azure pixels from the input grid to the output grid
for i in range(input_grid.shape[0]):
    for j in range(input_grid.shape[1]):
        if input_grid[i, j] == 8 and output_grid[i, j] != 1:
            output_grid[i, j] = 8

print(output_grid)
