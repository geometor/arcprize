        if input_grid[i, j] == 8:
            # Find the bottom-left most Azure pixel in the blob
            center_i, center_j = find_blob_center(input_grid, i, j)
            bottom_left_i, bottom_left_j = i, j
            for k in range(input_grid.shape[0]):
                for l in range(input_grid.shape[1]):
